# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, you probably want to ignore it.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if others have different platform or python version, they may not be able to install.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be committed.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended to be committed.
.pdm-python
.pdm-build/

# PEP 582; project local packages directory (used by pdm)
